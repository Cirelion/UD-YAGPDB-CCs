{{/*
	Image Contest -- Prompt Suggest
	Trigger Type: Command
	Trigger: suggest
	Usage: -suggest Post Title | Description of the challenge...

	Users submit prompt ideas for the next image contest.
	The pipe character separates the short post title from the
	creative description. Both are required. The bot posts an embed
	in the suggestions channel and adds a vote emoji.
*/}}

{{/* ========== CONFIGURATION ========== */}}
{{ $SUGGESTIONS_CHANNEL := 1482647243730321611 }}
{{ $SUGGESTION_EMOJI := "❤️" }}
{{ $EMBED_COLOR := 0x9B59B6 }}   {{/* Embed color */}}
{{/* ========== END CONFIGURATION ========== */}}

{{/* Always delete the trigger -- the tracker CC also does this, but belt-and-suspenders */}}
{{ deleteTrigger 0 }}

{{/* Error responses auto-delete after 5s so the suggestions channel stays clean */}}
{{ if not .CmdArgs }}
	{{ $m := sendMessageRetID nil (printf "Usage: `%ssuggest Post Title | Description`\nExample: `%ssuggest Goth Grinch | The Grinch dressed in dramatic goth style -- black clothes, chains, piercings.`\nBoth a title and description are required, separated by `|`." .ServerPrefix .ServerPrefix) }}
	{{ deleteMessage nil $m 8 }}
	{{ return }}
{{ end }}

{{ if ne .Channel.ID $SUGGESTIONS_CHANNEL }}
	{{ $m := sendMessageRetID nil (printf "This command can only be used in <#%d>." $SUGGESTIONS_CHANNEL) }}
	{{ deleteMessage nil $m 5 }}
	{{ return }}
{{ end }}

{{/* Parse title and description separated by | */}}
{{ $raw := .StrippedMsg }}
{{ $parts := split $raw "|" }}

{{ if lt (len $parts) 2 }}
	{{ $m := sendMessageRetID nil (printf "You must separate the title and description with a `|`.\nExample: `%ssuggest Goth Grinch | The Grinch dressed in dramatic goth style.`" .ServerPrefix) }}
	{{ deleteMessage nil $m 8 }}
	{{ return }}
{{ end }}

{{ $title := trimSpace (index $parts 0) }}
{{ $desc := trimSpace (slice $parts 1 | joinStr "|" | trimSpace) }}

{{ if or (not $title) (not $desc) }}
	{{ $m := sendMessageRetID nil (printf "Both a title and description are required.\nExample: `%ssuggest Goth Grinch | The Grinch dressed in dramatic goth style.`" .ServerPrefix) }}
	{{ deleteMessage nil $m 8 }}
	{{ return }}
{{ end }}

{{ if gt (len $title) 200 }}
	{{ $m := sendMessageRetID nil "Post title too long. Keep it under 200 characters." }}
	{{ deleteMessage nil $m 5 }}
	{{ return }}
{{ end }}

{{ if gt (len $desc) 1500 }}
	{{ $m := sendMessageRetID nil "Description too long. Keep it under 1500 characters." }}
	{{ deleteMessage nil $m 5 }}
	{{ return }}
{{ end }}

{{ $embed := cembed
	"title" $title
	"description" $desc
	"author" (sdict "name" .User.Username "icon_url" (.User.AvatarURL "256"))
	"footer" (sdict "text" (printf "React with %s to vote for this prompt!" $SUGGESTION_EMOJI))
	"color" $EMBED_COLOR
	"timestamp" currentTime
}}

{{ $msgID := sendMessageRetID $SUGGESTIONS_CHANNEL $embed }}
{{ addMessageReactions $SUGGESTIONS_CHANNEL $msgID $SUGGESTION_EMOJI }}

{{ dbSet 0 (printf "ic_prompt_%d" $msgID) (sdict
	"title" $title
	"desc" $desc
	"authorID" (str .User.ID)
	"msgID" (str $msgID)
	"channelID" (str $SUGGESTIONS_CHANNEL)
) }}
